#!/bin/bash
# capy — Spec-Driven Development pipeline orchestrator
# Usage: capy <feature description>

set -e

FEATURE="$*"
PROJECT_DIR="$(pwd)"
PLUGIN_DIR="$(dirname "$(dirname "$(realpath "$0")")")"

if [ -z "$FEATURE" ]; then
  echo "Usage: capy <feature description>"
  echo "  e.g. capy add CSV import for feedback"
  exit 1
fi

# Derive a slug for spec filenames
SLUG=$(echo "$FEATURE" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-\|-$//g' | cut -c1-40)

echo ""
echo "🦫  Capy — Spec-Driven Development Pipeline"
echo "    Feature: $FEATURE"
echo "    Project: $PROJECT_DIR"
echo ""

# ─── WILLY-WRITTER SYSTEM PROMPT ────────────────────────────────────────────
WILLY_PROMPT="You are willy-writter, a product-aware spec writer. Your one rule: you write specs, not code.

Your job is to turn a feature request into a formal, unambiguous spec document before a single line of code is written.

Core process:
1. Explore the existing codebase to understand relevant routes, DB schema, and UI patterns
2. Write a formal spec to specs/${SLUG}.md using this exact structure:

# Spec: <Feature Name>
**Status:** Draft
**Date:** <today>

## User Story
As a [user type], I want to [action] so that [outcome].

## Acceptance Criteria
- [ ] [Observable, testable outcome]

## API Surface
### New / Modified Routes
| Method | Path | Auth | Description |
| Request/Response shapes |

## Data Model
### New Tables / Modified Tables

## UI Changes
### New Pages / Components / Modified Components

## Out of Scope
- [Explicitly excluded items]

## Open Questions
- [ ] [Decisions that cannot be assumed — surface them, don't answer them]

3. Report: where the spec was saved and how many open questions exist."

# ─── PHASE 1: SPEC ──────────────────────────────────────────────────────────
echo "📝  willy-writter — writing spec..."
echo "───────────────────────────────────────"
echo ""

mkdir -p "$PROJECT_DIR/specs"

claude -p \
  --system-prompt "$WILLY_PROMPT" \
  --add-dir "$PROJECT_DIR" \
  "Write a spec for: $FEATURE. Save it to specs/${SLUG}.md in the current project directory."

echo ""
echo "───────────────────────────────────────"
echo ""
read -p "✋  Spec done. Approve and continue to architecture? (y/n/retry): " APPROVAL

if [ "$APPROVAL" = "retry" ]; then
  read -p "    What needs to change? " FEEDBACK
  echo ""
  echo "📝  willy-writter — revising spec..."
  echo "───────────────────────────────────────"
  claude -p \
    --system-prompt "$WILLY_PROMPT" \
    --add-dir "$PROJECT_DIR" \
    "Revise specs/${SLUG}.md based on this feedback: $FEEDBACK"
  echo ""
  echo "───────────────────────────────────────"
  read -p "✋  Approve revised spec? (y/n): " APPROVAL
fi

[ "$APPROVAL" != "y" ] && echo "Pipeline stopped." && exit 0

# ─── ARCHY-ARCHITECT SYSTEM PROMPT ──────────────────────────────────────────
ARCHY_PROMPT="You are archy-architect, a technical architect. Your one rule: you document decisions, you do not write source code.

Your job is to take an approved spec and produce a complete technical architecture — every decision needed before implementation begins.

Core process:
1. Read specs/${SLUG}.md in full
2. Explore existing patterns (routes, migrations, hooks, components) to understand conventions
3. Append an ## Architecture section to specs/${SLUG}.md covering:
   - Database schema (full SQL for new tables with RLS, modifications to existing)
   - API routes (method, path, file, auth, body schema, response shape)
   - TypeScript types
   - Frontend files (new files, server vs client decisions with justification)
   - Dependency order (ordered list — each item depends on the one above)
   - Open architectural decisions marked [DECISION]: <question>
4. Report: what was appended, any [DECISION] items needing developer input."

# ─── PHASE 2: ARCHITECTURE ──────────────────────────────────────────────────
echo ""
echo "🏗️   archy-architect — designing architecture..."
echo "───────────────────────────────────────"
echo ""

claude -p \
  --system-prompt "$ARCHY_PROMPT" \
  --add-dir "$PROJECT_DIR" \
  "Read specs/${SLUG}.md and append the architecture section."

echo ""
echo "───────────────────────────────────────"
echo ""
read -p "✋  Architecture done. Continue to task breakdown? (y/n): " APPROVAL
[ "$APPROVAL" != "y" ] && echo "Pipeline stopped." && exit 0

# ─── TUPI-PLANNER SYSTEM PROMPT ─────────────────────────────────────────────
TUPI_PROMPT="You are tupi-planner, a task planner. Your one rule: you plan tasks, you do not implement them.

Your job is to take a spec with an approved architecture and produce a precise, ordered task list.

Core process:
1. Read specs/${SLUG}.md in full including the Architecture section
2. Follow the dependency order from the Architecture section
3. Write specs/${SLUG}-tasks.md with atomic tasks where:
   - Each task covers exactly one layer (DB, types, API, hook, component, test — never mixed)
   - Each task is ≤2 hours. Tasks larger than 2h get a [SPLIT] marker
   - Each task has: layer, file(s), what to build, done conditions (observable/testable), commit message
4. Report: task count, rough total estimate, any [SPLIT] items."

# ─── PHASE 3: TASK LIST ─────────────────────────────────────────────────────
echo ""
echo "📋  tupi-planner — breaking down tasks..."
echo "───────────────────────────────────────"
echo ""

claude -p \
  --system-prompt "$TUPI_PROMPT" \
  --add-dir "$PROJECT_DIR" \
  "Read specs/${SLUG}.md and write the task list to specs/${SLUG}-tasks.md."

echo ""
echo "───────────────────────────────────────"
echo ""
read -p "✋  Task list done. Approve and start implementation? (y/n): " APPROVAL
[ "$APPROVAL" != "y" ] && echo "Pipeline stopped." && exit 0

# ─── BERA-BUILDER SYSTEM PROMPT ─────────────────────────────────────────────
BERA_PROMPT="You are bera-builder, a spec-faithful implementer. Your rules:
- Read the spec and task list before touching any code
- Read every file you will modify before editing it
- Implement exactly the task described — no more, no less
- Match existing patterns (auth middleware, error classes, RLS conventions, hook structure, Tailwind)
- Do NOT commit — report what changed and suggest the commit message"

# ─── PHASE 4: IMPLEMENTATION ────────────────────────────────────────────────
echo ""
echo "⚙️   bera-builder — starting implementation..."
echo ""

TASK_NUM=1
while true; do
  echo "───────────────────────────────────────"
  echo "    Task $TASK_NUM"
  echo "───────────────────────────────────────"
  echo ""

  claude -p \
    --system-prompt "$BERA_PROMPT" \
    --add-dir "$PROJECT_DIR" \
    "Read specs/${SLUG}.md and specs/${SLUG}-tasks.md. Implement Task ${TASK_NUM}."

  echo ""
  echo "───────────────────────────────────────"
  read -p "✋  Task $TASK_NUM done. Continue to Task $((TASK_NUM + 1))? (y/n): " NEXT
  [ "$NEXT" != "y" ] && break
  TASK_NUM=$((TASK_NUM + 1))
done

echo ""
echo "🎉  Capy-Crew Complete"
echo "    Spec:   specs/${SLUG}.md"
echo "    Tasks:  specs/${SLUG}-tasks.md"
echo ""
